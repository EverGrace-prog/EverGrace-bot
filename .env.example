# ========================
# EverGrace Bot - .env.example
# Copy this file to `.env` and replace values with your real ones.
# NEVER commit the real `.env` file to GitHub.
# ========================

# Telegram bot token from BotFather
BOT_TOKEN=your-telegram-bot-token-here

# OpenAI API key (for GPT responses)
OPENAI_API_KEY=your-openai-api-key-here

# Supabase project anon key (safe for client-side)
SUPABASE_KEY=your-supabase-anon-key-here

# Supabase service role key (keep secret, server-side only)
SUPABASE_SERVICE_ROLE=your-supabase-service-role-key-here

# Supabase project URL
SUPABASE_URL=https://your-project-id.supabase.co
